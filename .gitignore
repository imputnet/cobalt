# ============================================
# KILOCODE CONFIGURATION - Generated artifacts
# ============================================
# Never commit vendored dependencies or lockfiles
# in the .kilocode directory. These should be
# installed on-demand or managed at project level.
.kilocode/node_modules/
.kilocode/bun.lock
.kilocode/package-lock.json
.kilocode/pnpm-lock.yaml
.kilocode/yarn.lock

